{
  "sourceLanguage" : "en",
  "strings" : {
    "\"Keep recording during password entry\": normally recording pauses while a password field is edited so secrets stay out of the clip. When on, the field's content (including the briefly shown last-typed character) is recorded — use it only to capture a bug around password entry." : {
      "comment" : "SettingsView: debug-section footer explaining the secure-entry guard toggle and its risk.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「パスワード入力中も録画を続ける」：通常はパスワード欄の編集中、秘密がクリップに写らないよう録画を一時停止します。オンにすると欄の内容（入力中に一瞬表示される末尾の文字を含む）が録画されます。パスワード入力まわりの不具合を録りたいときだけオンにしてください。"
          }
        }
      }
    },
    "%lld sec" : {
      "comment" : "SettingsView: retention option label, e.g. \"20 sec\".",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld 秒"
          }
        }
      }
    },
    "Add %@ to the title" : {
      "comment" : "ReportView: accessibility label for the + button that appends a device-info value to the title.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "タイトルへ%@を追加"
          }
        }
      }
    },
    "Cancel" : {
      "comment" : "ReportView: accessibility label for the ✕ (close) button.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャンセル"
          }
        }
      }
    },
    "Capture this moment as an image" : {
      "comment" : "VideoTrimmerView: accessibility label for the still-capture button under the playhead.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この瞬間を画像で保存"
          }
        }
      }
    },
    "Close" : {
      "comment" : "FlashbackPresenter: dismiss button for the standalone debug settings screen.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "閉じる"
          }
        }
      }
    },
    "Confirm permission on launch" : {
      "comment" : "SettingsView: toggle title for prompting screen-recording permission on launch.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アプリ起動時に権限を確認する"
          }
        }
      }
    },
    "Couldn't write out the memory" : {
      "comment" : "FlashbackController: failure toast when clip export fails.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "記憶の書き出しに失敗しました"
          }
        }
      }
    },
    "Debug" : {
      "comment" : "SettingsView: header for the debug section.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "デバッグ"
