    },
    "Title" : {
      "comment" : "ReportView: label for the title field.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "タイトル"
          }
        }
      }
    },
    "Turn screen recording on" : {
      "comment" : "PermissionPrimingView: title heading for the priming sheet.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "画面収録をオンにします"
          }
        }
      }
    },
    "Usually unnecessary. Turn this on only when you want the launch button to appear in OS screenshots/recordings, e.g. for documentation." : {
      "comment" : "SettingsView: footer for the debug section.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "通常は不要です。ドキュメント用に起動ボタンを OS のスクショ/録画へ写したいときだけオンにします。"
          }
        }
      }
    },
    "When \"Confirm permission on launch\" is on, screen-recording permission is confirmed right after launch. (Due to iOS, a persistent always-allow in Settings isn't possible.)" : {
      "comment" : "SettingsView: footer for the recording (permission) section.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「アプリ起動時に権限を確認する」をオンにすると、起動直後に画面収録の許可を確認します。（iOS の仕様上、設定での常時許可はできません。）"
          }
        }
      }
    },
    "When you choose \"Allow\" on the next iOS prompt, your latest in-app activity is kept automatically." : {
      "comment" : "PermissionPrimingView: explanatory body of the priming sheet.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "次に表示される iOS の確認で「許可」を選ぶと、アプリ内の直前の操作を自動で保持できます。"
          }
        }
      }
    },
    "iOS asks to confirm screen recording" : {
      "comment" : "PermissionPrimingView: accessibility hint that the OS prompt will appear.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS の画面収録の確認が表示されます"
          }
        }
      }
    },
