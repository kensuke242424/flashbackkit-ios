      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "表示"
          }
        }
      }
    },
    "Drag left or right to adjust, then share the frame at the playhead as an image." : {
      "comment" : "VideoTrimmerView: accessibility hint for the still-capture button.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "再生ヘッドの位置の画面を画像として共有します。左右ドラッグで位置調整。"
          }
        }
      }
    },
    "End" : {
      "comment" : "VideoTrimmerView: accessibility label for the trim end handle.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "終了位置"
          }
        }
      }
    },
    "Enter a title" : {
      "comment" : "ReportView: placeholder for the title text field.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "タイトルを入力"
          }
        }
      }
    },
    "Environment" : {
      "comment" : "ReportView: header for the device-info section.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "環境情報"
          }
        }
      }
    },
    "From the next launch on, your recent activity is kept automatically." : {
      "comment" : "ReportView: body of the just-enabled state (no clip captured this time).",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "次回の起動操作から、直前の操作を自動で保持します。"
          }
        }
      }
    },
    "Keep recording during password entry" : {
      "comment" : "SettingsView: debug-section toggle that disables the secure-entry privacy guard (on = keep recording while a password field is edited).",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "パスワード入力中も録画を続ける"
          }
        }
      }
    },
    "Keep the selected number of seconds of recording at all times, and write it out when triggered. Longer uses more memory." : {
      "comment" : "SettingsView: footer for the retention-length section.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "選択した秒数の録画を常に保持し、発火時に書き出します。長いほどメモリを使います。"
          }
        }
      }
    },
    "Later" : {
      "comment" : "PermissionPrimingView: dismiss button (defer enabling).",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あとで"
          }
        }
      }
    },
    "Launch Flashback" : {
